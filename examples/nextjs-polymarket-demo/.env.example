# Required: Your Dynamic Labs environment ID
# Get this from https://app.dynamic.xyz
NEXT_PUBLIC_DYNAMIC_ENV_ID=

# Checkout.com credentials (for credit card deposits)
CHECKOUT_SECRET_KEY=
NEXT_PUBLIC_CHECKOUT_PUBLIC_KEY=
CHECKOUT_PROCESSING_CHANNEL_ID=
CHECKOUT_API_URL=

# Optional: LiFi API key for higher rate limits on cross-chain deposits
# Get this from https://li.fi
NEXT_PUBLIC_LIFI_API_KEY=
