# Required: Dynamic environment ID from https://app.dynamic.xyz
NEXT_PUBLIC_DYNAMIC_ENV_ID=your-environment-id-here

# Required: Solana RPC URL (or configure one in the Dynamic dashboard)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Required: Merchant wallet address whose subscription plans to display
NEXT_PUBLIC_MERCHANT_ADDRESS=your-merchant-wallet-address-here

# Optional: Token mint for subscriptions (defaults to devnet USDC)
NEXT_PUBLIC_TOKEN_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Optional: Token program address (defaults to SPL Token)
NEXT_PUBLIC_TOKEN_PROGRAM=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
