# Required: Dynamic environment ID from https://app.dynamic.xyz
NEXT_PUBLIC_DYNAMIC_ENV_ID=your-environment-id-here

# Required: Solana mainnet RPC URL with getProgramAccounts support.
# Public endpoints block getProgramAccounts — use a private RPC from
# Helius (https://helius.dev), QuickNode, or Alchemy.
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-api-key-here

# Required: Merchant wallet address whose subscription plans to display
NEXT_PUBLIC_MERCHANT_ADDRESS=your-merchant-wallet-address-here

# Optional: Token mint for subscriptions (defaults to mainnet USDC)
NEXT_PUBLIC_TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Required for Dynamic Checkout funding (server-side only — never expose to client).
# Create an API token at https://app.dynamic.xyz/dashboard/developer/api
DYNAMIC_API_TOKEN=dyn_your_api_token_here

# Optional: USDC mint for checkout settlement (defaults to Solana mainnet USDC).
NEXT_PUBLIC_CHECKOUT_SETTLEMENT_TOKEN=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
