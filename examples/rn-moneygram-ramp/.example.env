EXPO_PUBLIC_DYNAMIC_ENVIRONMENT_ID=your_dynamic_environment_id_here

# URL of the MoneyGram session server (see server/). On a physical device,
# use your machine's LAN IP instead of localhost.
EXPO_PUBLIC_SESSION_URL=http://localhost:3001/api/moneygram-session

# USDC mint for the active Solana network (devnet shown here).
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
EXPO_PUBLIC_SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Optional — MoneyGram API base. Defaults to the widget origin's /api.
# EXPO_PUBLIC_RAMPS_API_URL=https://playground.xramps.moneygram.com/api
