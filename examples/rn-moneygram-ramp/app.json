{
  "expo": {
    "name": "MoneyGram Ramp",
    "slug": "rn-moneygram-ramp",
    "version": "1.0.0",
    "backgroundColor": "#0f1117",
    "orientation": "portrait",
    "scheme": "mgr",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dynamic.moneygram-ramp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f1117"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.dynamic.moneygramramp"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      ["expo-splash-screen", { "backgroundColor": "#0f1117", "resizeMode": "contain" }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
